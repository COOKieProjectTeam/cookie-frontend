# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
NEXT_PUBLIC_API_TIMEOUT=10000

# Authentication (NextAuth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-minimum-32-characters-long

# OAuth Providers
YANDEX_CLIENT_ID=your-yandex-oauth-client-id
YANDEX_CLIENT_SECRET=your-yandex-oauth-client-secret
VK_CLIENT_ID=your-vk-oauth-client-id
VK_CLIENT_SECRET=your-vk-oauth-client-secret

# Object Storage
NEXT_PUBLIC_OBJECT_STORAGE_URL=https://storage.yandexcloud.net/cookie-dev

# Feature Flags
NEXT_PUBLIC_ENABLE_RATINGS=true
NEXT_PUBLIC_ENABLE_COMMENTS=false

# Analytics (Phase 2)
# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
